# SmartUML Client Environment Variables Example

# Backend API Base URL (leave empty or set to localhost for development)
# In production on Vercel/Netlify, set this to your deployed FastAPI URL (e.g., https://smartuml-api.onrender.com)
VITE_API_BASE_URL=http://127.0.0.1:8000

# Firebase Credentials
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
